# Discord
DISCORD_TOKEN=
# Routing mode: per_channel | master
DISCORD_ROUTE_MODE=per_channel
# Used when DISCORD_ROUTE_MODE=master
DISCORD_MASTER_CHANNEL_ID=
# Fallback channel (used in per_channel mode for unmatched hashes; also used as
# fallback in master mode if DISCORD_MASTER_CHANNEL_ID is empty)
DISCORD_DEFAULT_CHANNEL_ID=

# MQTT
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC=meshcore/#
MQTT_TLS=false
MQTT_TLS_INSECURE=false
MQTT_CA_CERT=
MQTT_TRANSPORT=tcp
MQTT_WS_PATH=/mqtt
MQTT_CLIENT_ID=
MQTT_QOS=0

# Channel routing
CHANNELS_FILE=channels.json

# Relay behavior
RELAY_DEDUPE_SECONDS=45
LOG_LEVEL=info
# Optional observer filter (comma-separated names, case-insensitive)
MQTT_OBSERVER_ALLOWLIST=
# Optional message path display in relayed Discord messages
RELAY_SHOW_PATH=false
# Discord embed color (#RRGGBB)
RELAY_EMBED_COLOR="#1e2938"
# Time window to collect additional hops before posting
RELAY_PATH_WAIT_MS=1200
# If true, edit sent Discord messages when additional hops are heard
RELAY_PATH_EDIT_UPDATES=true
# Max time to keep editing path updates for a message
RELAY_PATH_EDIT_WINDOW_MS=15000
# Minimum time between path edit API calls
RELAY_PATH_EDIT_MIN_INTERVAL_MS=3000
# Max hops shown in the path line
RELAY_PATH_MAX_OBSERVERS=8
